<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#fdf0d5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#003049"
            android:orientation="vertical"
            android:padding="24dp"
            android:gravity="center">

            <LinearLayout
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:background="#FFFFFF"
                android:gravity="center">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="👤"
                    android:textSize="32sp"/>
            </LinearLayout>

            <TextView
                android:id="@+id/tv_profile_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="User"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginTop="8dp"/>

            <TextView
                android:id="@+id/tv_profile_email"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="user@todoapp.com"
                android:textColor="#CCFFFFFF"
                android:textSize="13sp"/>

            <TextView
                android:id="@+id/tv_task_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0/0 tasks done"
                android:textColor="#AAFFFFFF"
                android:textSize="12sp"
                android:layout_marginTop="4dp"/>
        </LinearLayout>

        <!-- Language -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="LANGUAGE"
            android:textColor="#888888"
            android:textSize="11sp"
            android:textStyle="bold"
            android:layout_margin="16dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="12dp">

            <TextView android:id="@+id/btn_language_english"
                android:layout_width="0dp" android:layout_height="40dp"
                android:layout_weight="1" android:gravity="center"
                android:text="English" android:background="#1A237E"
                android:textColor="#FFFFFF" android:textSize="13sp"/>

            <TextView android:id="@+id/btn_language_french"
                android:layout_width="0dp" android:layout_height="40dp"
                android:layout_weight="1" android:gravity="center"
                android:text="Français" android:background="#E8EAF6"
                android:textColor="#1A237E" android:textSize="13sp"
                android:layout_marginStart="8dp"/>

            <TextView android:id="@+id/btn_language_arabic"
                android:layout_width="0dp" android:layout_height="40dp"
                android:layout_weight="1" android:gravity="center"
                android:text="العربية" android:background="#E8EAF6"
                android:textColor="#1A237E" android:textSize="13sp"
                android:layout_marginStart="8dp"/>
        </LinearLayout>

        <!-- Share -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ACTIONS"
            android:textColor="#888888"
            android:textSize="11sp"
            android:textStyle="bold"
            android:layout_marginStart="16dp"
            android:layout_marginTop="8dp"/>

        <LinearLayout
            android:id="@+id/btn_share_task"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:background="#FFFFFF"
            android:padding="16dp"
            android:gravity="center_vertical"
            android:layout_marginHorizontal="12dp"
            android:layout_marginTop="8dp">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="📤  Share My Tasks"
                android:textColor="#1A1A2E"
                android:textSize="14sp"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="›"
                android:textColor="#888888"
                android:textSize="20sp"/>
        </LinearLayout>

        <!-- Logout -->
        <TextView
            android:id="@+id/btn_logout"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:gravity="center"
            android:text="Log Out"
            android:background="#FFEBEE"
            android:textColor="#C0392B"
            android:textSize="15sp"
            android:textStyle="bold"
            android:layout_margin="16dp"/>

    </LinearLayout>
</ScrollView>
